# Bỏ qua database local
db.json
data_announcements.json

# Bỏ qua cache Python
__pycache__/
*.pyc

# Bỏ qua file backup
backup/
db_backups/

# Bỏ qua secrets (khóa Google API)
key.json

# Bỏ qua file test cục bộ
test_*.py

# Runtime uploads (do not commit binaries)
static/uploads/*
!static/uploads/.gitkeep
!static/uploads/avatars/
!static/uploads/avatars/.gitkeep
!static/uploads/lineups/
!static/uploads/lineups/.gitkeep

# Disallow binary image/database artifacts
*.png
*.jpg
*.jpeg
*.webp
*.gif
*.db
*.sqlite
